identifier tack.hello_world

fn void start() {
    const components: [string] = ["Hello, ", "World!"]
    print!(components)
    println()
}

identifier tack.variables

fn void start() {
    let x: i32 = 5
    const y: i32 = 7
    
    print(x) // Outputs "5"
    x = 9
    print(x) // Outputs "9"
    print(y) // Objects "7"
    y = 2 // ERROR: cannot re-assign value to constant
}